from gensim.models import Word2Vec

data = [
    ["doctor", "treats", "patient"],
    ["nurse", "help", "doctor"],
    ["medicine", "cures", "disease"]
]

m = Word2Vec(data, vector_size=50, min_count=1)

print("Similar to doctor:",
      m.wv.most_similar("doctor"))

print("Analysis: captures medical relationship")
